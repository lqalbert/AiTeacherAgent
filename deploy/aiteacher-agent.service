[Unit]
Description=AiTeacherAgent 智能课堂助手 (Node + Express)
Documentation=file:///home/ubuntu/AiTeacherAgent/deploy/DEPLOY.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/AiTeacherAgent
Environment=NODE_ENV=production
EnvironmentFile=/home/ubuntu/AiTeacherAgent/.env
ExecStart=/usr/bin/node server/index.js
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target

# 复制到项目根目录 .env（例如 /home/ubuntu/AiTeacherAgent/.env）
# systemd 使用 EnvironmentFile= 指向该文件

PORT=3200
NODE_ENV=production

# 登录鉴权密钥（生产务必修改为随机长串）
AUTH_SECRET=please-change-this-to-a-long-random-secret

# 讯飞实时语音转写
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
ASR_PROVIDER=rtasr_llm
XFYUN_ASR_LANG=autodialect
XFYUN_ASR_PD=edu
XFYUN_ASR_VAD=2

# AI 分析 / 字幕校对（至少配置一个）
DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
AI_PROVIDER=deepseek
ASR_AI_POLISH=true
# ASR_HOTWORDS=本课专有名词,术语1,术语2
ASR_DIALECT_HINT=普通话与四川方言混合

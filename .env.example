# 讯飞实时语音转写 https://www.xfyun.cn/
XFYUN_APP_ID=
XFYUN_API_KEY=
# 大模型版必填（控制台 Websocket 接口认证信息中的 APISecret）
XFYUN_API_SECRET=

# rtasr_llm（实时语音转写大模型，推荐）| rtasr（标准版）| iat（语音听写）
ASR_PROVIDER=rtasr_llm

# 识别优化：edu=教育场景，vad 2=近场麦克风（课堂推荐）
XFYUN_ASR_PD=edu
XFYUN_ASR_VAD=2
# 说话人分离：0=关闭（默认），2=开启盲分（需控制台开通后再设）
XFYUN_ASR_ROLE_TYPE=0

# AI 分析（至少配置一个）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# deepseek | dashscope
AI_PROVIDER=deepseek

# 实时字幕 AI 校对（需 DEEPSEEK_API_KEY 或 DASHSCOPE_API_KEY，设为 false 可关闭）
ASR_AI_POLISH=true
ASR_AI_POLISH_TIMEOUT_MS=2500
# 学科热词，逗号分隔，帮助纠正专有名词（可选）
# ASR_HOTWORDS=定语从句,名词所有格,先行词,关系代词

PORT=3200
